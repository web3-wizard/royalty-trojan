# Production Environment Variables Template
# Copy this to `.env.production.local` and fill in actual values
# .env.production.local should NEVER be committed to git

NODE_ENV=production

# Server Configuration
PORT=3001
HOST=0.0.0.0

# Redis Configuration
# Format: redis://[username:password@]host[:port]
# Example: redis://default:myStrongPassword@redis-instance.us-east-1.render.com:6379
# Get this from your Redis instance dashboard
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@your-redis-host.render.com:6379

# Rate Limiting
# Max requests per time window
RATE_LIMIT_MAX=200

# Time window for rate limiting
RATE_LIMIT_WINDOW=1 minute

# Cache Configuration
# Time-to-live for cached wallet addresses (in seconds)
# Set higher (7200 = 2 hours) for less frequent updates
# Set lower (1800 = 30 min) if DNS records change frequently
CACHE_TTL=3600

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-key@sentry.io/your-project

# Optional: Analytics
# AMPLITUDE_API_KEY=your-api-key
