{
  "manifest_version": 3,
  "name": "Royalty Trojan",
  "version": "0.1.0",
  "description": "Direct on-chain subscriptions for creators",
  "permissions": ["storage", "activeTab", "notifications", "alarms"],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.x.com/*",
    "https://*.twitch.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Royalty Trojan"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.x.com/*",
        "https://*.twitch.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-pause-all": {
      "suggested_key": { "default": "Ctrl+Shift+P" },
      "description": "Pause/Resume all Bags streams"
    }
  }
}