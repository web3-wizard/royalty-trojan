{
    "manifest_version":  3,
    "name":  "Royalty Trojan",
    "version":  "0.2.0",
    "description":  "Direct on-chain subscriptions for creators",
    "permissions":  [
                        "storage",
                        "activeTab"
                    ],
    "host_permissions":  [
                             "https://*.youtube.com/*",
                             "https://*.x.com/*",
                             "https://*.twitch.tv/*"
                         ],
    "background":  {
                       "service_worker":  "background.js",
                       "type":  "module"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://*.youtube.com/*",
                                                "https://*.x.com/*",
                                                "https://*.twitch.tv/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "assets/*"
                                                       ],
                                         "matches":  [
                                                         "\u003call_urls\u003e"
                                                     ]
                                     }
                                 ],
    "action":  {
                   "default_title":  "Royalty Trojan - Open Settings"
               },
    "options_page":  "settings.html",
    "browser_specific_settings":  {
                                      "gecko":  {
                                                    "id":  "royalty-trojan@web3-wizard.com",
                                                    "strict_min_version":  "121.0"
                                                }
                                  }
}
